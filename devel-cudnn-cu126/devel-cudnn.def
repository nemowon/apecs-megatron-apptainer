Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04

%post -c /bin/bash
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates locales \
        wget curl git cmake \
        build-essential ninja-build \
        python3-dev python3.12-dev python3.12-venv python3-pip 
    locale-gen en_US.UTF-8

    # ---- Python venv (install everything at build time) ----
    python3.12 -m venv --copies /usr/local/venv
    . /usr/local/venv/bin/activate
    python -V
    pip install -U --no-cache-dir pip setuptools wheel packaging

    # CUDA 12.6 wheels (24.12 stack)
    pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu126 \
        torch==2.6.0+cu126 \
        torchvision==0.21.0+cu126 \
        torchaudio==2.6.0+cu126

    # Megatron-Core & TE (prebuilt PyTorch wheels; no build isolation)
    pip install --no-cache-dir 'megatron-core==0.10.*'
    # megatron-core 0.10.0 does not provide the extra 'dev'
    pip install --no-cache-dir --no-build-isolation "transformer-engine[pytorch]"

    pip install --no-cache-dir \
        "transformers==4.57.1" \
        "datasets==4.2.0" \
        pybind11

    # Keep image lean
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    # [rank3]: RuntimeError: ColumnParallelLinear was called with gradient_accumulation_fusion set to True but the custom CUDA extension fused_weight_gradient_mlp_cuda module is not found. To use gradient_accumulation_fusion you must install APEX with --cpp_ext and --cuda_ext. For example: pip install --global-option="--cpp_ext" --global-option="--cuda_ext ." Note that the extension requires CUDA>=11. Otherwise, you must turn off gradient accumulation fusion.


%environment
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export VIRTUAL_ENV=/usr/local/venv
    export PATH=/usr/local/venv/bin:/usr/local/cuda-12.6/bin:/usr/local/cuda/bin:$PATH
    export CUDA_HOME=/usr/local/cuda-12.6
    export LD_LIBRARY_PATH=/usr/local/cuda-12.6/lib64:/usr/local/cuda/lib64:${LD_LIBRARY_PATH}
    export PYTHONUNBUFFERED=1
    export PYTHONNOUSERSITE=1


